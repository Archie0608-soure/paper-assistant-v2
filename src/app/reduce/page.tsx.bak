'use client';

import { useState } from 'react';
import { ArrowLeft, Scale, Loader2, Check, FileText, X } from 'lucide-react';
import { useRouter } from 'next/navigation';

const PLATFORMS = [
  { id: 'zhiwang', label: '知网' },
  { id: 'vip', label: '维普' },
  { id: 'gezada', label: '格子达' },
  { id: 'daya', label: '大雅' },
  { id: 'wanfang', label: '万方' },
];

export default function ReducePage() {
  const router = useRouter();
  const [mode, setMode] = useState<'plagiarism' | 'ai' | 'both'>('both');
  const [lang, setLang] = useState<'chinese' | 'english'>('chinese');
  const [platform, setPlatform] = useState('zhiwang');
  const [input, setInput] = useState('');
  const [output, setOutput] = useState('');
  const [loading, setLoading] = useState(false);
  const [fileName, setFileName] = useState('');
  const [fileSize, setFileSize] = useState('');

  const countWords = (t: string) => t ? t.replace(/\s/g, '').length : 0;

  const handleFileUpload = async (file: File) => {
    const ext = file.name.split('.').pop()?.toLowerCase();
    if (!['txt', 'docx'].includes(ext || '')) {
      alert('仅支持 .txt 和 .docx 文件');
      return;
    }
    setFileName(file.name);
    setFileSize((file.size / 1024 / 1024).toFixed(2) + ' MB');
    try {
      let text = '';
      if (ext === 'txt') {
        text = await file.text();
      } else if (ext === 'docx') {
        const { default: mammoth } = await import('mammoth');
        const arrayBuffer = await file.arrayBuffer();
        const result = await mammoth.extractRawText({ arrayBuffer });
        text = result.value;
      }
      setInput((prev) => prev ? prev + '\n\n' + text : text);
    } catch (err) {
      alert('文件解析失败');
    }
  };

  const handleProcess = async () => {
    if (!input.trim()) return;
    setLoading(true);
    setOutput('');
    try {
      const res = await fetch('/api/ai/reduce', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: input, language: lang, platform, mode }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || '处理失败');
      setOutput(data.result || data.text || '');
    } catch (err: any) {
      alert(err.message || '处理失败');
    } finally {
      setLoading(false);
    }
  };

  const modeLabel = mode === 'plagiarism' ? '降重' : mode === 'ai' ? '降AI' : '降重降AI';
  const coinsPerThousand = mode === 'both' ? 60 : 40;
  const words = countWords(input);
  const estimatedCoins = Math.ceil(words / 1000) * coinsPerThousand;

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100">
      {/* 顶部导航 */}
      <header className="bg-white border-b border-slate-200 sticky top-0 z-20">
        <div className="max-w-4xl mx-auto px-4 py-3 flex items-center gap-4">
          <button onClick={() => router.push('/')}
            className="flex items-center gap-2 text-slate-600 hover:text-slate-900 transition-colors duration-150">
            <ArrowLeft className="w-5 h-5" />
            <span>返回首页</span>
          </button>
          <div className="flex-1" />
          <div className="flex items-center gap-2">
            <div className="w-8 h-8 bg-gradient-to-br from-orange-500 to-red-600 rounded-lg flex items-center justify-center">
              <Scale className="w-4 h-4 text-white" />
            </div>
            <span className="font-bold text-slate-900">降重降AI</span>
          </div>
        </div>
      </header>

      <main className="max-w-4xl mx-auto px-4 py-8 space-y-5">
        {/* 模式选择 */}
        <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 transition-all duration-200">
          <h2 className="text-base font-semibold text-slate-800 mb-4">处理模式</h2>
          <div className="grid grid-cols-3 gap-3">
            {[
              { id: 'plagiarism', label: '单降重', desc: '降低重复率' },
              { id: 'ai', label: '单降AI', desc: '降低AI生成率' },
              { id: 'both', label: '降重降AI', desc: '双重处理' },
            ].map((m) => (
              <button key={m.id} onClick={() => setMode(m.id as any)}
                className={[
                  'p-4 rounded-xl border-2 text-center transition-all duration-200 ease-out',
                  mode === m.id
                    ? 'border-orange-500 bg-orange-50 shadow-md scale-[1.02]'
                    : 'border-slate-200 hover:border-orange-300 hover:bg-orange-50/50'
                ].join(' ')}>
                <div className="text-base font-semibold mb-1">{m.label}</div>
                <div className="text-xs text-slate-500">{m.desc}</div>
              </button>
            ))}
          </div>
        </div>

        {/* 语言 + 平台 */}
        <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <div className="grid grid-cols-2 gap-6">
            <div>
              <h2 className="text-base font-semibold text-slate-800 mb-3">语言</h2>
              <div className="grid grid-cols-2 gap-2">
                {[
                  { id: 'chinese', label: '中文' },
                  { id: 'english', label: '英文' },
                ].map((l) => (
                  <button key={l.id} onClick={() => setLang(l.id as any)}
                    className={[
                      'py-2.5 rounded-lg text-sm font-medium border-2 transition-all duration-150',
                      lang === l.id
                        ? 'border-orange-500 bg-orange-50 text-orange-700 shadow-sm'
                        : 'border-slate-200 text-slate-600 hover:border-orange-300 hover:bg-orange-50/50'
                    ].join(' ')}>
                    {l.label}
                  </button>
                ))}
              </div>
            </div>
            <div>
              <h2 className="text-base font-semibold text-slate-800 mb-3">目标平台</h2>
              <div className="grid grid-cols-2 gap-2">
                {PLATFORMS.map((p) => (
                  <button key={p.id} onClick={() => setPlatform(p.id)}
                    className={[
                      'py-2 rounded-lg text-sm font-medium border-2 transition-all duration-150',
                      platform === p.id
                        ? 'border-orange-500 bg-orange-50 text-orange-700 shadow-sm'
                        : 'border-slate-200 text-slate-600 hover:border-orange-300 hover:bg-orange-50/50'
                    ].join(' ')}>
                    {p.label}
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>

        {/* 上传文档 */}
        <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <h2 className="text-base font-semibold text-slate-800 mb-4">上传文档</h2>
          <div
            className="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center transition-all duration-200 cursor-pointer bg-slate-50 hover:bg-orange-50/50 hover:border-orange-400"
            onClick={() => document.getElementById('file-input')?.click()}
            onDragOver={(e) => { e.preventDefault(); }}
            onDrop={(e) => {
              e.preventDefault();
              const f = e.dataTransfer.files[0];
              if (f) handleFileUpload(f);
            }}>
            <input id="file-input" type="file" accept=".txt,.docx" className="hidden"
              onChange={(e) => { const f = e.target.files?.[0]; if (f) handleFileUpload(f); }} />
            <FileText className="w-12 h-12 mx-auto text-slate-400 mb-3" />
            <p className="text-slate-600 font-medium">点击上传或拖拽文件</p>
            <p className="text-xs text-slate-400 mt-1">支持 .txt / .docx 文件</p>
          </div>
          {fileName ? (
            <div className="mt-3 flex items-center gap-2 text-sm text-green-600">
              <Check className="w-4 h-4" />
              <span>{fileName}</span>
              <span className="text-slate-400">({fileSize})</span>
              <button onClick={() => { setFileName(''); setFileSize(''); setInput(''); }}
                className="ml-auto text-slate-400 hover:text-red-500 transition-colors">
                <X className="w-4 h-4" />
              </button>
            </div>
          ) : null}
        </div>

        {/* 输入 */}
        <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <div className="flex items-center justify-between mb-3">
            <h2 className="text-base font-semibold text-slate-800">原文内容</h2>
            <div className="text-xs text-slate-400">{words.toLocaleString()} 字 · 约 {Math.ceil(words / 400)} 分钟</div>
          </div>
          <textarea
            value={input}
            onChange={(e) => setInput(e.target.value)}
            className="w-full h-64 px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all duration-200 resize-none text-sm"
            placeholder="粘贴或输入需要处理的论文内容..."
          />
        </div>

        {/* 预估费用 */}
        <div className="text-center text-sm text-slate-500 transition-all duration-200">
          预估费用：<span className="font-semibold text-orange-600">{estimatedCoins}</span> 金币（{coinsPerThousand}金币/千字）
        </div>

        {/* 处理按钮 */}
        <button
          onClick={handleProcess}
          disabled={!input.trim() || loading}
          className="w-full py-4 bg-gradient-to-r from-orange-500 to-red-600 text-white rounded-2xl font-bold text-base hover:from-orange-600 hover:to-red-700 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-3 shadow-lg shadow-orange-200 hover:shadow-xl hover:shadow-orange-200 hover:-translate-y-0.5">
          {loading ? (
            <><Loader2 className="w-6 h-6 animate-spin" /> 处理中，请稍候...</>
          ) : (
            <><Scale className="w-6 h-6" /> 一键{modeLabel}</>
          )}
        </button>

        {/* 结果 */}
        {output ? (
          <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-4 animate-fade-in">
            <div className="flex items-center justify-between">
              <h2 className="text-base font-semibold text-slate-800">处理结果</h2>
              <button onClick={() => navigator.clipboard.writeText(output)}
                className="text-sm text-orange-600 hover:text-orange-700 font-medium transition-colors">
                复制结果
              </button>
            </div>
            <div className="bg-green-50 border border-green-200 rounded-xl p-4">
              <p className="text-sm text-green-800 whitespace-pre-wrap leading-relaxed">{output}</p>
            </div>
            <button onClick={() => { setInput(output); setOutput(''); }}
              className="w-full py-2 border border-slate-300 text-slate-600 rounded-xl text-sm hover:bg-slate-50 transition-colors">
              基于结果继续处理
            </button>
          </div>
        ) : null}

        {/* 提示 */}
        <div className="bg-slate-50 rounded-2xl p-5 text-sm text-slate-500 space-y-1">
          <p className="font-medium text-slate-700">💡 使用提示</p>
          <p>• 建议单次处理 500-3000 字，效果最佳</p>
          <p>• 不同检测平台算法不同，建议根据目标平台选择</p>
          <p>• 处理后的文本建议通读后使用</p>
          <p>• API 接入后自动对接知网/维普等检测接口</p>
        </div>
      </main>
    </div>
  );
}
